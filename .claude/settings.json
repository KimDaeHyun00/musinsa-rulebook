{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/tools/save_log.py\" --tool claude-code"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/tools/save_log.py\" --tool claude-code"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "insane-search@gptaku-plugins": true
  }
}
